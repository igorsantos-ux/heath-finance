generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Clinic {
  id                    String          @id @default(uuid())
  name                  String          // Nome de exibição principal
  razaoSocial           String?
  cnpj                  String?         @unique
  inscricaoEstadual     String?
  inscricaoMunicipal    String?
  cnae                  String?
  regimeTributario      String?         @default("SIMPLES")
  dataAbertura          DateTime?
  cep                   String?
  logradouro            String?
  numero                String?
  complemento           String?
  bairro                String?
  cidade                String?
  estado                String?
  telefone              String?
  whatsapp              String?
  email                 String?
  site                  String?
  codigoServico         String?
  aliquotaISS           Float?
  certificadoDigitalUrl String?
  banco                 String?
  agencia               String?
  conta                 String?
  tipoConta             String?
  chavePix              String?
  logo                  String?
  corMarca              String?
  responsavelAdmin      String?
  responsavelTecnico    String?
  crmResponsavel        String?
  registroVigilancia    String?
  cnes                  String?
  pricePerUser          Float           @default(50.0)
  isActive              Boolean         @default(true)
  users                 User[]
  transactions          Transaction[]
  doctors               Doctor[]
  customers             Customer[]
  stockItems            StockItem[]
  goals                 FinancialGoal[]
  documents             Document[]
  integrations          Integration[]
  createdAt             DateTime        @default(now())
}

model Integration {
  id          String   @id @default(uuid())
  type        String   // "FEEGOW", etc.
  token       String
  settings    Json?    // Configurações adicionais em JSON
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clinicId    String
  clinic      Clinic   @relation(fields: [clinicId], references: [id])

  @@unique([clinicId, type])
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   // "ADMIN_GLOBAL" or "CLINIC_ADMIN"
  clinicId  String?
  clinic    Clinic?  @relation(fields: [clinicId], references: [id])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Transaction {
  id            String   @id @default(uuid())
  description   String
  amount        Float
  netAmount     Float    @default(0) // Valor líquido (pós taxas)
  type          String   // "INCOME" or "EXPENSE"
  status        String   @default("PAID") // "PAID", "PENDING", "OVERDUE"
  paymentMethod String?  // "Cartão", "Pix", "Dinheiro", etc.
  category      String   // "Tecnologias", "Procedimentos", "Produtos", "Fixo", "Variável"
  centerOfCost  String   @default("Operacional")
  procedureName String?
  cost          Float    @default(0)
  date          DateTime @default(now())
  
  doctorId      String?
  doctor        Doctor?  @relation(fields: [doctorId], references: [id])
  
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])
  
  clinicId      String
  clinic        Clinic   @relation(fields: [clinicId], references: [id])
}

model Doctor {
  id           String        @id @default(uuid())
  name         String
  specialty    String
  commission   Float
  transactions Transaction[]
  
  clinicId     String
  clinic       Clinic        @relation(fields: [clinicId], references: [id])
}

model Customer {
  id             String        @id @default(uuid())
  name           String
  email          String?
  phone          String?
  birthDate      DateTime?
  lastVisit      DateTime?
  externalId     String?       // ID no sistema de origem (ex: Feegow)
  externalSource String?       // Qual plataforma de origem (ex: "FEEGOW")
  transactions   Transaction[]
  createdAt      DateTime      @default(now())
  
  clinicId       String
  clinic         Clinic        @relation(fields: [clinicId], references: [id])

  @@unique([externalId, externalSource, clinicId])
}

model Lead {
  id        String   @id @default(uuid())
  name      String
  source    String
  status    String
  createdAt DateTime @default(now())
}

model StockItem {
  id           String   @id @default(uuid())
  name         String
  category     String
  quantity     Int
  minQuantity  Int
  price        Float
  lastRestock  DateTime @default(now())
  
  clinicId     String
  clinic       Clinic   @relation(fields: [clinicId], references: [id])
}

model FinancialGoal {
  id        String   @id @default(uuid())
  month     Int
  year      Int
  target    Float
  achieved  Float    @default(0)
  type      String
  
  clinicId  String
  clinic    Clinic @relation(fields: [clinicId], references: [id])
}

model Document {
  id        String   @id @default(uuid())
  name      String
  url       String
  type      String   // "Contract", "PatientDoc", "Admin"
  category  String?
  createdAt DateTime @default(now())
  
  clinicId  String
  clinic    Clinic @relation(fields: [clinicId], references: [id])
}
